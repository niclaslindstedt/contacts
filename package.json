{
  "name": "contacts",
  "version": "0.1.0",
  "private": true,
  "description": "A local-first contacts PWA built on @niclaslindstedt/oss-framework \u2014 folders, namespaces, photos, encryption, themes, achievements, and export to vCard/CSV for Outlook, iOS, and Android.",
  "license": "PolyForm-Noncommercial-1.0.0",
  "author": "Niclas Lindstedt <niclas@agilator.se>",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . && tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "fmt": "prettier --write .",
    "fmt:check": "prettier --check .",
    "icons": "node scripts/generate-icons.mjs",
    "check:seo": "node scripts/check-seo.mjs"
  },
  "dependencies": {
    "@fontsource/inter": "^5.2.5",
    "@fontsource/jetbrains-mono": "^5.2.5",
    "@fontsource/opendyslexic": "^5.2.5",
    "@fontsource/source-serif-4": "^5.2.5",
    "@niclaslindstedt/oss-framework": "^2.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "workbox-window": "^7.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.1",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^10.5.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "prettier": "^3.4.2",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=22"
  }
