# Example build-time environment for contacts. Copy to `.env` (which is
# git-ignored) and fill in as needed. All vars are optional — the app builds
# and runs without any of them. See `docs/configuration.md` for the full list.

# Seed the developer "Fake data" backend at startup, so the dev server comes up
# pre-loaded with varied test contacts (edge cases: nameless cards, very long
# and unicode/RTL text, many phones/emails, leap-day birthdays, every postal /
# phone style, archived cards, folders). In-memory only — nothing is persisted.
#
#   VITE_SEED=1        # the curated edge-case sample set
#   VITE_SEED=250      # roughly this many contacts (sample + generated bulk)
#   VITE_SEED=large    # a big stress-test spread
#   VITE_SEED=0        # off — start on the real address book
#
# `npm run dev` already sets `VITE_SEED=large` by default; `npm run dev:clean`
# starts with no seed. Override the default with e.g. `VITE_SEED=25 npm run dev`.
# VITE_SEED=large

# Dropbox app key (PKCE public client). Unset hides the Dropbox storage backend
# in Settings → Storage. Register an app at
# https://www.dropbox.com/developers/apps (scoped access, "App folder").
# VITE_DROPBOX_APP_KEY=

# Google OAuth client id (GIS token client). Unset hides the Google Drive
# storage backend. Create an OAuth client id in the Google Cloud console with
# the Drive API enabled.
# VITE_GOOGLE_CLIENT_ID=
